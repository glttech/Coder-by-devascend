// Prisma schema defining the database models for the ai‑dev‑orchestrator.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  name          String?
  passwordHash  String?
  role          String     @default("admin")  // "admin" | "reviewer"
  approvals     Approval[]
  auditLogs     AuditLog[]
  assignedTasks Task[]     @relation("TaskAssignee")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Project {
  id            String      @id @default(uuid())
  name          String
  description   String?
  repoOwner     String?
  repoName      String?
  defaultBranch String      @default("main")
  tasks         Task[]
  milestones    Milestone[]
  githubPRs     GithubPR[]
  ciRuns        CiRun[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Task {
  id                String             @id @default(uuid())
  title             String
  instruction       String
  projectId         String
  project           Project            @relation(fields: [projectId], references: [id])
  agentTool         String             // e.g. "open-swe", "claude-code-manual", etc.
  riskLevel         String             // "low", "medium", "high"
  environment       String             // "local", "dev", "staging", "production"
  approvalRequired  Boolean
  status            String             @default("pending") // "pending", "running", "completed", "failed"
  priority          String             @default("medium")  // "low", "medium", "high", "critical"
  dueDate           DateTime?
  assigneeId        String?
  assignee          User?              @relation("TaskAssignee", fields: [assigneeId], references: [id])
  milestoneId       String?
  milestone         Milestone?         @relation(fields: [milestoneId], references: [id])
  module            String?            @default("coder")   // "coder" | "soc"
  agentRuns         AgentRun[]
  approval          Approval?
  audits            AuditLog[]
  operatorSessions  OperatorSession[]
  instructions      Instruction[]
  comments          Comment[]
  incidents         Incident[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([module])
  @@index([createdAt])
  @@index([projectId, createdAt])
}

model Milestone {
  id          String     @id @default(uuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id])
  title       String
  description String?
  targetDate  DateTime?
  status      String     @default("open") // "open" | "completed"
  tasks       Task[]
  githubPRs   GithubPR[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model PromptTemplate {
  id        String   @id @default(uuid())
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentProvider {
  id        String     @id @default(uuid())
  name      String     // "mock", "claude-code", "codex", "open-swe"
  type      String     // "mock" | "claude" | "codex" | "open-swe"
  enabled   Boolean    @default(false) // all disabled by default
  config    Json?      // non-secret config only (model name, endpoint, etc.)
  agentRuns AgentRun[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model AgentRun {
  id               String         @id @default(uuid())
  taskId           String
  task             Task           @relation(fields: [taskId], references: [id])
  providerId       String?
  provider         AgentProvider? @relation(fields: [providerId], references: [id])
  generatedPrompt  String
  selectedTool     String
  response         String?
  filesChanged     String?
  commandsRun      String?
  testResult       String?
  commitHash       String?
  // Intended lifecycle: draft → awaiting_approval → queued → running → succeeded | failed | blocked | cancelled | preview
  status           String         @default("pending") // "pending", "running", "succeeded", "failed", "preview"
  sandboxPlan      String?        // JSON: { plannedFiles, plannedCommands, estimatedRisk, warnings }
  startedAt        DateTime       @default(now())
  endedAt          DateTime?
  // Agent Role System — all nullable/defaulted, additive only
  roleKey          String?
  modelUsed        String?
  structuredOutput String?        @db.Text
  riskScore        Float?
  promptTokens     Int?           @default(0)
  completionTokens Int?           @default(0)
  cachedTokens     Int?           @default(0)
  evaluations      Evaluation[]
  audits           AuditLog[]
  steps            AgentStep[]
  githubPRs        GithubPR[]
  incidents        Incident[]
}

model AgentStep {
  id         String   @id @default(uuid())
  agentRunId String
  agentRun   AgentRun @relation(fields: [agentRunId], references: [id])
  stepIndex  Int
  type       String   // "prompt", "tool_call", "tool_result", "text", "error"
  content    String
  metadata   Json?
  createdAt  DateTime @default(now())
}

model Evaluation {
  id         String    @id @default(uuid())
  agentRunId String
  agentRun   AgentRun  @relation(fields: [agentRunId], references: [id])
  name       String
  passed     Boolean
  score      Float?
  reason     String?
  createdAt  DateTime  @default(now())
}

model Approval {
  id         String    @id @default(uuid())
  taskId     String    @unique
  task       Task      @relation(fields: [taskId], references: [id])
  approverId String?
  approved   Boolean?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User?     @relation(fields: [approverId], references: [id])
}

model AuditLog {
  id                String           @id @default(uuid())
  taskId            String?
  agentRunId        String?
  operatorSessionId String?
  instructionId     String?
  userId            String?
  event             String
  details           String?
  createdAt         DateTime         @default(now())
  task              Task?            @relation(fields: [taskId], references: [id])
  agentRun          AgentRun?        @relation(fields: [agentRunId], references: [id])
  operatorSession   OperatorSession? @relation(fields: [operatorSessionId], references: [id])
  instruction       Instruction?     @relation(fields: [instructionId], references: [id])
  user              User?            @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([createdAt])
}

model Instruction {
  id           String      @id @default(uuid())
  taskId       String
  task         Task        @relation(fields: [taskId], references: [id])
  title        String
  body         String
  // Lifecycle: draft | pending_approval | approved | executing | completed | blocked
  status       String      @default("draft")
  approvedBy      String?
  approvedAt      DateTime?
  approvalNote    String?
  executingAt     DateTime?
  resolvedAt      DateTime?
  blockedReason   String?
  completedNotes  String?
  // SHA256 of stable fields; recomputed on every create/update.
  stateVersion    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  auditLogs    AuditLog[]
}

model OperatorSession {
  id                     String     @id @default(uuid())
  taskId                 String
  task                   Task       @relation(fields: [taskId], references: [id])
  currentStep            Int        @default(1)
  operatorInput          String?
  generatedPrompt        String?
  agentTool              String?
  agentResponse          String?
  filesMentioned         String[]   @default([])
  commandsMentioned      String[]   @default([])
  validationOutput       String?
  reviewerNotes          String?
  riskFlags              String[]   @default([])
  missingEvidence        String[]   @default([])
  recommendedAction      String?
  seniorApprovalRequired Boolean    @default(false)
  decisionReason         String?
  nextPrompt             String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  auditLogs              AuditLog[]
}

model Invitation {
  id        String   @id @default(uuid())
  orgId     String   @default("org_default")
  email     String
  role      String   @default("reviewer")
  token     String   @unique
  invitedBy String
  status    String   @default("pending")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([email])
}

model ShareLink {
  id          String    @id @default(uuid())
  entityType  String    // task_report
  entityId    String
  token       String    @unique
  expiresAt   DateTime?
  revokedAt   DateTime?
  viewCount   Int       @default(0)
  createdBy   String    @default("system")
  createdAt   DateTime  @default(now())
  @@index([entityId])
}

model Comment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model CiRun {
  id        String   @id @default(cuid())
  projectId String
  prId      String?
  workflow  String
  status    String
  url       String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ActiveSession {
  id        String    @id @default(uuid())
  sessionId String    @unique
  userId    String
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  type       String   // "approval_needed" | "run_completed" | "run_failed" | "session_revoked"
  title      String
  body       String?
  read       Boolean  @default(false)
  taskId     String?
  agentRunId String?
  createdAt  DateTime @default(now())
}


model GithubPR {
  id                String    @id @default(uuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id])
  taskId            String?
  milestoneId       String?
  milestone         Milestone? @relation(fields: [milestoneId], references: [id])
  agentRunId        String?
  agentRun          AgentRun?  @relation(fields: [agentRunId], references: [id])
  prNumber          Int
  title             String
  body              String?
  author            String?
  sourceBranch      String?
  baseBranch        String?
  state             String    // "open", "closed", "merged"
  merged            Boolean   @default(false)
  mergeSha          String?
  labels            String[]  @default([])
  filesChangedCount Int?
  filesChanged      String[]  @default([])
  ciStatus          String?   // "pending", "success", "failure", "neutral"
  prUrl             String?
  githubCreatedAt   DateTime?
  githubUpdatedAt   DateTime?
  githubMergedAt    DateTime?
  // PR Memory Index (Feature 1) — auto-populated on import/refresh
  classification       String?  // "feature"|"bug_fix"|"security"|"migration"|"deployment"|"rollback"|"incident"|"chore"|"test"|"docs"
  classificationSource String?  // "auto_title"|"auto_label"|"auto_files"|"manual"
  bugState             String?  // null|"known_issue"|"fixed"|"regression_risk"|"needs_retest"
  reviewDecision       String?  // "approved"|"changes_requested"|"dismissed"|null
  commentCount         Int?
  syncedAt             DateTime?
  importedAt        DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([projectId, prNumber])
  @@index([projectId, classification])
  @@index([projectId, bugState])
  @@index([projectId, githubMergedAt])
  @@index([importedAt])
}

// Tracks incremental sync state per project — one row per project.
model PrSyncState {
  projectId          String   @id
  lastSyncedAt       DateTime?
  lastSyncedPrNumber Int?
  totalSynced        Int      @default(0)
  syncStatus         String   @default("idle") // "idle"|"running"|"error"
  errorMessage       String?
  updatedAt          DateTime @updatedAt
}

model Diagram {
  id         String   @id @default(uuid())
  orgId      String   @default("org_default")
  entityType String   // "task" | "project"
  entityId   String
  kind       String   // "lifecycle" | "architecture"
  title      String
  source     String   @db.Text
  svg        String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityId])
  @@index([orgId])
}

model Organization {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  plan        String       @default("free")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
}

model Membership {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  userId    String
  role      String       @default("reviewer")
  createdAt DateTime     @default(now())
  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId])
}

model NotificationPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  emailInvite     Boolean  @default(true)
  emailApproval   Boolean  @default(true)
  emailRunDone    Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model ApiKey {
  id          String    @id @default(uuid())
  orgId       String
  name        String
  prefix      String
  keyHash     String    @unique
  scopes      String[]
  createdBy   String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([orgId])
  @@index([keyHash])
}

model Webhook {
  id              String    @id @default(uuid())
  orgId           String
  url             String
  secret          String?
  events          String[]
  enabled         Boolean   @default(true)
  failureCount    Int       @default(0)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orgId])
}

model AgentRole {
  id           String   @id @default(uuid())
  orgId        String   @default("org_default")
  key          String   // e.g. "security_reviewer"
  name         String
  description  String?
  systemPrompt String   @db.Text
  allowedTools String[] @default([])
  maxRiskLevel String   @default("medium") // "low" | "medium" | "high"
  outputFormat String   @default("structured_findings")
  modelPref    String   @default("claude-opus-4-8")
  enabled      Boolean  @default(true)
  isBuiltIn    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([orgId, key])
  @@index([orgId])
}

model ExecutionTrace {
  id                String   @id @default(uuid())
  orgId             String   @default("org_default")
  taskId            String?
  agentRunId        String?
  roleKey           String?
  promptSent        String?  @db.Text  // redacted before persist
  modelUsed         String?
  toolCallsSummary  String?  // JSON summary of tool calls, redacted
  evidenceRefs      String?  // JSON array of evidence references
  riskScore         Float?
  riskFlags         String?  // JSON array of risk flag keys
  decisionCode      String?  // CONTINUE | RUN_VALIDATION | SENIOR_APPROVAL_REQUIRED | BLOCKED
  approvalState     String?  // pending | approved | rejected | not_required
  finalOutput       String?  @db.Text  // redacted before persist
  promptTokens      Int?
  completionTokens  Int?
  createdAt         DateTime @default(now())
  // NO updatedAt — append-only by design

  @@index([orgId, taskId])
  @@index([agentRunId])
}

// ---------------------------------------------------------------------------
// RAG Foundation (PR 2.4)
// Stores text chunks with deterministic stub embeddings for retrieval-augmented
// governance analysis. Real embedding calls are gated behind FEATURE_RAG_EMBED.
// ---------------------------------------------------------------------------

model EvidenceChunk {
  id          String   @id @default(uuid())
  orgId       String   @default("org_default")
  taskId      String?
  // Source metadata
  sourceType  String   // "task_instruction" | "agent_response" | "audit_log" | "manual"
  sourceRef   String?  // e.g. agentRunId, instructionId, auditLogId
  // Content
  content     String   @db.Text
  // Embedding stored as a JSON-serialised float array (stub = zero vector).
  // Real embeddings written only when FEATURE_RAG_EMBED=true.
  embedding   String?  @db.Text
  embeddingModel String? // e.g. "stub-v0", "text-embedding-3-small"
  // Retrieval metadata
  chunkIndex  Int      @default(0)
  tokenCount  Int?
  createdAt   DateTime @default(now())

  @@index([orgId, taskId])
  @@index([sourceType])
}

model Incident {
  id               String    @id @default(uuid())
  taskId           String?
  task             Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agentRunId       String?
  agentRun         AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  title            String
  description      String?
  trigger          String    // "ci_failure" | "reviewer_block" | "policy_block" | "run_failure" | "manual_rollback"
  severity         String    @default("medium")
  status           String    @default("open")
  timeline         String?   // JSON: Array<{ timestamp: string, event: string, actor?: string }>
  failedCommand    String?
  failedTest       String?
  riskCategory     String?
  reviewerDecision String?
  followUpAction   String?
  resolvedAt       DateTime?
  resolvedBy       String?
  module           String?   @default("coder")  // "coder" | "soc"
  alertId          String?   // FK to SecurityAlert (SOC incidents only)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([module])
  @@index([createdAt])
}

model SecurityAlert {
  id                   String    @id @default(uuid())
  orgId                String

  // Source
  source               String    // 'wazuh' | 'sentry' | 'manual'
  sourceId             String?   // original ID in source system
  sourceRef            String?   // URL or external reference

  // Normalized fields
  title                String
  description          String?
  ruleId               String?

  // MITRE ATT&CK
  mitreTactic          String?
  mitreTechniqueId     String?
  mitreTechnique       String?

  // Severity & status
  severity             String    @default("medium")
                                 // 'info' | 'low' | 'medium' | 'high' | 'critical'
  status               String    @default("new")
                                 // 'new' | 'triaging' | 'escalated' | 'closed'
  triageScore          Float?
  triageRecommendation String?   // 'acknowledge' | 'escalate' | 'close'
  triageConfidence     Float?
  triageReason         String?
  triageBy             String?
  triagedAt            DateTime?

  // Linked incident
  incidentId           String?

  // Raw payload (for replay/debugging, never rendered as HTML)
  rawPayload           Json?

  // Timestamps
  alertedAt            DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  // Soft-delete — set by DELETE /api/soc/alerts/[id]; null = active
  archivedAt           DateTime?

  @@index([orgId, status])
  @@index([orgId, severity])
  @@index([orgId, source])
  @@index([createdAt])
}