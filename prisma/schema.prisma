// Prisma schema defining the database models for the ai‑dev‑orchestrator.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  approvals Approval[]
  auditLogs AuditLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id            String    @id @default(uuid())
  name          String
  description   String?
  repoOwner     String?
  repoName      String?
  defaultBranch String    @default("main")
  tasks         Task[]
  githubPRs     GithubPR[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Task {
  id                String             @id @default(uuid())
  title             String
  instruction       String
  projectId         String
  project           Project            @relation(fields: [projectId], references: [id])
  agentTool         String             // e.g. "open-swe", "claude-code-manual", etc.
  riskLevel         String             // "low", "medium", "high"
  environment       String             // "local", "dev", "staging", "production"
  approvalRequired  Boolean
  status            String             @default("pending") // "pending", "running", "completed", "failed"
  agentRuns         AgentRun[]
  approval          Approval?
  audits            AuditLog[]
  operatorSessions  OperatorSession[]
  instructions      Instruction[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model PromptTemplate {
  id        String   @id @default(uuid())
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentRun {
  id             String      @id @default(uuid())
  taskId         String
  task           Task        @relation(fields: [taskId], references: [id])
  generatedPrompt String
  selectedTool   String
  response       String?
  filesChanged   String?
  commandsRun    String?
  testResult     String?
  commitHash     String?
  status         String      @default("pending") // "pending", "running", "succeeded", "failed"
  startedAt      DateTime    @default(now())
  endedAt        DateTime?
  evaluations    Evaluation[]
  audits         AuditLog[]
}

model Evaluation {
  id         String    @id @default(uuid())
  agentRunId String
  agentRun   AgentRun  @relation(fields: [agentRunId], references: [id])
  name       String
  passed     Boolean
  score      Float?
  reason     String?
  createdAt  DateTime  @default(now())
}

model Approval {
  id         String    @id @default(uuid())
  taskId     String    @unique
  task       Task      @relation(fields: [taskId], references: [id])
  approverId String?
  approved   Boolean?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User?     @relation(fields: [approverId], references: [id])
}

model AuditLog {
  id                String           @id @default(uuid())
  taskId            String?
  agentRunId        String?
  operatorSessionId String?
  instructionId     String?
  userId            String?
  event             String
  details           String?
  createdAt         DateTime         @default(now())
  task              Task?            @relation(fields: [taskId], references: [id])
  agentRun          AgentRun?        @relation(fields: [agentRunId], references: [id])
  operatorSession   OperatorSession? @relation(fields: [operatorSessionId], references: [id])
  instruction       Instruction?     @relation(fields: [instructionId], references: [id])
  user              User?            @relation(fields: [userId], references: [id])
}

model Instruction {
  id           String      @id @default(uuid())
  taskId       String
  task         Task        @relation(fields: [taskId], references: [id])
  title        String
  body         String
  // Lifecycle: draft | pending_approval | approved | executing | completed | blocked
  status       String      @default("draft")
  approvedBy      String?
  approvedAt      DateTime?
  approvalNote    String?
  executingAt     DateTime?
  resolvedAt      DateTime?
  blockedReason   String?
  completedNotes  String?
  // SHA256 of stable fields; recomputed on every create/update.
  stateVersion    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  auditLogs    AuditLog[]
}

model OperatorSession {
  id                     String     @id @default(uuid())
  taskId                 String
  task                   Task       @relation(fields: [taskId], references: [id])
  currentStep            Int        @default(1)
  operatorInput          String?
  generatedPrompt        String?
  agentTool              String?
  agentResponse          String?
  filesMentioned         String[]   @default([])
  commandsMentioned      String[]   @default([])
  validationOutput       String?
  reviewerNotes          String?
  riskFlags              String[]   @default([])
  missingEvidence        String[]   @default([])
  recommendedAction      String?
  seniorApprovalRequired Boolean    @default(false)
  decisionReason         String?
  nextPrompt             String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  auditLogs              AuditLog[]
}

model GithubPR {
  id                String    @id @default(uuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id])
  taskId            String?
  prNumber          Int
  title             String
  body              String?
  author            String?
  sourceBranch      String?
  baseBranch        String?
  state             String    // "open", "closed", "merged"
  merged            Boolean   @default(false)
  mergeSha          String?
  labels            String[]  @default([])
  filesChangedCount Int?
  filesChanged      String[]  @default([])
  ciStatus          String?   // "pending", "success", "failure", "neutral"
  prUrl             String?
  githubCreatedAt   DateTime?
  githubUpdatedAt   DateTime?
  githubMergedAt    DateTime?
  importedAt        DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([projectId, prNumber])
}

model Organization {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  plan        String       @default("free")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
}

model Membership {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  userId    String
  role      String       @default("reviewer")
  createdAt DateTime     @default(now())
  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId])
}