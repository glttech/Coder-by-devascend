# Copy this file to .env and fill in the values before running the app.

# PostgreSQL connection string.
# Docker Compose: postgresql://postgres:postgres@localhost:5432/aidv?schema=public
# Native Postgres: postgresql://postgres:<password>@localhost:5432/aidv?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aidv?schema=public"

# Langfuse observability (Phase 1: leave blank — stubs log to console only)
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# ── Auth (optional — leave unset to disable login for local dev) ────────────
#
# When both ADMIN_USERNAME and ADMIN_PASSWORD_HASH are set, the login page
# is activated and all browser sessions require authentication.
# If only one is set, the server will refuse to start auth routes (misconfigured).
#
# Generate a bcrypt hash offline (cost 12):
#   node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
#
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
# Optional: session lifetime in hours (default: 24)
SESSION_MAX_AGE_HOURS=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Feature flags ─────────────────────────────────────────────────────────────
# Billing feature flag (default: off)
FEATURE_BILLING=false
# Orchestration feature flag — set to 'true' to enable agent dispatch UI
ORCHESTRATION_ENABLED=false
# Set to "true" to enable in-app notifications (off by default).
NOTIFICATIONS_ENABLED=false
# Real LLM calls for agent governance roles (default: off — uses deterministic stubs)
FEATURE_AGENT_LLM=false
# Real embeddings for RAG retrieval (default: off — uses stub embeddings)
FEATURE_RAG_EMBED=false

# ── LLM / Embedding API keys (only needed when feature flags above are true) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
